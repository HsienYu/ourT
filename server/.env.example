# Copy this file to .env and fill in your keys
# Never commit .env to git

# Required: OpenAI API key with Realtime API access
OPENAI_API_KEY=sk-...

# Optional text-generation providers for KTV lyric rewrites and analysis
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=

# Optional: server port (default 3000)
PORT=3000

# KTV: auto-rewrite lyrics with LLM when audience requests a song
# Set to 'true' to enable (requires any configured text-generation provider)
KTV_AUTO_REWRITE=false

# Default LLM lyrics variant for auto-rewrite: gender-swap | emotional | distorted
KTV_DEFAULT_VARIANT=gender-swap
